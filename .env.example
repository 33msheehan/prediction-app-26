# ---- Database (Vercel Postgres / Neon) ----
# Pooled connection string used by the app at runtime.
POSTGRES_URL=
# Direct (non-pooled) connection, used by drizzle-kit migrations.
POSTGRES_URL_NON_POOLING=
# Generic alias some tools expect; can mirror POSTGRES_URL.
DATABASE_URL=

# ---- Auth.js (NextAuth v5) ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Set to your deployment URL in production (e.g. https://your-app.vercel.app)
AUTH_URL=http://localhost:3000
# If using the GitHub provider (T1.1):
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- LLM co-pilot (Phase 7) ----
# Server-only. NEVER prefix with NEXT_PUBLIC_ — it must not reach the client.
ANTHROPIC_API_KEY=

# ---- Feature flags ----
# Co-pilot decomposition stub is off by default (T7.2).
FEATURE_COPILOT_DECOMPOSITION=false
